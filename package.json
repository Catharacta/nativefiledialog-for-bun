{
  "name": "nativefiledialog-for-bun",
  "version": "0.2.0",
  "description": "Cross-platform native file dialogs (Open, Save, Pick Folder) for Bun.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "bun test",
    "build": "rm -rf dist && bun x tsc --declaration --emitDeclarationOnly --outDir dist && bun build ./src/index.ts --outdir ./dist --target bun --minify",
    "lint": "bun x eslint .",
    "format": "bun x prettier --write .",
    "postinstall": "bun run scripts/install-binary.ts",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "files": [
    "dist",
    "bin",
    "scripts",
    "README.md",
    "README.ja.md",
    "LICENSE"
  ],
  "keywords": [
    "bun",
    "native",
    "file",
    "dialog",
    "nfd",
    "nativefiledialog",
    "cross-platform",
    "native-file-dialog"
  ],
  "author": "Catharacta",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "bun-types": "latest",
    "typescript": "^5.0.0"
  }
}
